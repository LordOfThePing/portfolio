# Credentials for the admin area (/admin/stats and /admin/config).
# Set these in your host: Environment variables -> Add. BOTH are required.
# If either is missing, admin stays locked for everyone (fail-closed) — it
# never falls back to "no login required".
ADMIN_USER=
ADMIN_PASSWORD=

# Optional. Extra salt for signing the admin session cookie.
# Changing ADMIN_USER, ADMIN_PASSWORD or this value logs out all sessions.
ADMIN_SECRET=

# Supabase — backend for /links stats and the editable config.
# Dashboard -> Project Settings -> API.
#   SUPABASE_URL:              "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY: the "service_role" secret key (NOT the anon key).
# The service_role key bypasses row-level security and must stay server-side —
# it has no NEXT_PUBLIC_ prefix on purpose, so it never reaches the browser.
# Run supabase/schema.sql once (SQL Editor) to create the tables + function.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# For local dev: copy this file to .env.local and fill everything in. The app
# talks to the same Supabase in dev and prod (no local-file fallback).
