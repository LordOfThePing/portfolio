# Password for the admin stats page at /admin/stats.
# Set this in Netlify: Site configuration → Environment variables → Add.
# Without it, the admin page stays locked for everyone (fail-closed).
# Use something long and random.
ADMIN_PASSWORD=

# Optional. Extra salt for signing the admin session cookie.
# Changing either this or ADMIN_PASSWORD logs out all existing sessions.
ADMIN_SECRET=

# For local dev only: copy this file to .env.local and fill in a password.
# Click counters fall back to .metrics-dev.json locally; on Netlify they use
# Netlify Blobs automatically, with no configuration.
