# Credentials for the admin area (/admin/stats and /admin/config).
# Set these in Netlify: Site configuration -> Environment variables -> Add.
# BOTH are required. If either is missing, admin stays locked for everyone
# (fail-closed) — it never falls back to "no login required".
ADMIN_USER=
ADMIN_PASSWORD=

# Optional. Extra salt for signing the admin session cookie.
# Changing ADMIN_USER, ADMIN_PASSWORD or this value logs out all sessions.
ADMIN_SECRET=

# For local dev only: copy this file to .env.local and fill in credentials.
# Storage falls back to .metrics-dev.json / .links-dev.json locally; on Netlify
# it uses Netlify Blobs automatically, with no configuration.
